#!/usr/bin/env python3
"""Entry-point shim so `qm ...` works without installation.

Resolves the package directory relative to this script, then dispatches to the
CLI. Lets the plugin ship a runnable `qm` without a build step.
"""
import os
import sys

_here = os.path.dirname(os.path.abspath(__file__))
_root = os.path.dirname(_here)
if _root not in sys.path:
    sys.path.insert(0, _root)

from qm.cli import main  # noqa: E402

if __name__ == "__main__":
    raise SystemExit(main())
